<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- MCP servers must output all logs to STDERR, not STDOUT -->
    <!-- STDOUT is reserved exclusively for JSON-RPC protocol messages -->

    <appender name="STDERR" class="ch.qos.logback.core.ConsoleAppender">
        <target>System.err</target>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Set root logger to INFO level -->
    <root level="INFO">
        <appender-ref ref="STDERR" />
    </root>

    <!-- Set Spring framework logging to WARN to reduce noise -->
    <logger name="org.springframework" level="WARN"/>
    <logger name="org.springframework.boot" level="WARN"/>

    <!-- Keep application logging at INFO level -->
    <logger name="dev.danvega.dvaas" level="INFO"/>
</configuration>
